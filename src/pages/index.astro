---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import SubscribeButtons from "../components/SubscribeButtons.astro";

const allEpisodes = (await getCollection("episodes")).sort(
  (a, b) => b.data.pub_date.valueOf() - a.data.pub_date.valueOf()
);

// Show up to 9 most recent episodes on the homepage grid (no pinned featured)
const recent = allEpisodes.slice(0, 9);
---

<Layout>
  <section class="hero-fullpage">
    <video
      class="hero-video"
      autoplay muted loop playsinline preload="auto"
      aria-hidden="true"
    >
      <source src="/movie_1.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>

    <svg class="hero-waves" viewBox="0 0 1440 320" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="waveGrad" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="rgba(255,255,255,0.18)" />
          <stop offset="100%" stop-color="rgba(255,255,255,0.04)" />
        </linearGradient>
      </defs>
      <path class="wave wave-1" fill="url(#waveGrad)"
        d="M0,192L60,176C120,160,240,128,360,138.7C480,149,600,203,720,208C840,213,960,171,1080,154.7C1200,139,1320,149,1380,154.7L1440,160L1440,320L0,320Z"></path>
      <path class="wave wave-2" fill="url(#waveGrad)" opacity="0.7"
        d="M0,224L60,229.3C120,235,240,245,360,234.7C480,224,600,192,720,192C840,192,960,224,1080,229.3C1200,235,1320,213,1380,202.7L1440,192L1440,320L0,320Z"></path>
      <path class="wave wave-3" fill="rgba(255,255,255,0.95)"
        d="M0,256L60,261.3C120,267,240,277,360,277.3C480,267,600,267,720,261.3C840,256,960,256,1080,261.3C1200,267,1320,277,1380,282.7L1440,288L1440,320L0,320Z"></path>
    </svg>

    <div class="hero-content">
      <span class="hero-eyebrow">Daily · water research · AI-narrated</span>
      <h1 class="hero-title">The world's water research,<br />narrated every morning.</h1>
      <p class="hero-lede">
        A new peer-reviewed paper, distilled into a 10-minute conversation.
        No paywalls, no jargon — just the science shaping our water future.
      </p>
      <div class="hero-subscribe">
        <SubscribeButtons />
      </div>

      <!-- Intro audio player -->
      <div class="intro-player" data-intro-player>
        <audio id="intro-audio" src="/ep000.m4a" preload="metadata"></audio>

        <button class="ip-play" id="ip-play" aria-label="Play introduction">
          <svg class="ip-icon-play" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <svg class="ip-icon-pause" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" style="display:none"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
        </button>

        <div class="ip-info">
          <span class="ip-eyebrow">Start here · Introduction</span>
          <span class="ip-title">What is SpeakForWater?</span>
        </div>

        <div class="ip-progress" id="ip-progress">
          <div class="ip-progress-fill" id="ip-progress-fill"></div>
        </div>

        <div class="ip-time" id="ip-time">--:-- / --:--</div>
      </div>
    </div>

    <a href="#latest" class="scroll-indicator" aria-label="Scroll to episodes">
      <span></span>
    </a>
  </section>

  {recent.length > 0 && (
    <section class="section" id="latest">
      <div class="container">
        <div class="section-head">
          <h2>Recent episodes</h2>
          <a href="/episodes" class="all-link">
            View all {allEpisodes.length} episodes
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        <div class="episode-grid">
          {recent.map((ep) => (
            <EpisodeCard
              href={`/episodes/${ep.slug}`}
              number={ep.data.episode_number}
              title={ep.data.title}
              date={ep.data.pub_date}
              duration={ep.data.duration}
              journal={ep.data.paper.journal}
              topics={ep.data.topics}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section how">
    <div class="container-narrow">
      <span class="eyebrow">How it works</span>
      <h2>From paper to podcast, every weekday.</h2>
      <div class="steps">
        <div class="step">
          <span class="step-num">01</span>
          <h3>Discover</h3>
          <p>Each morning, we identify a new peer-reviewed open-access water research paper worth knowing about.</p>
        </div>
        <div class="step">
          <span class="step-num">02</span>
          <h3>Distill</h3>
          <p>Two hosts unpack the paper in a natural conversation: methodology, findings, and what it means for everyday water users.</p>
        </div>
        <div class="step">
          <span class="step-num">03</span>
          <h3>Publish</h3>
          <p>Episodes drop here and on every major podcast platform — fully transcribed, citation-linked, and free to listen forever.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const heroVideo = document.querySelector<HTMLVideoElement>(".hero-video");
  if (heroVideo) {
    heroVideo.playbackRate = 0.5;
    heroVideo.addEventListener("loadeddata", () => {
      heroVideo.playbackRate = 0.5;
    });
  }

  // ── Intro audio player ─────────────────────────────────────────
  const audio = document.getElementById("intro-audio") as HTMLAudioElement | null;
  const playBtn = document.getElementById("ip-play");
  const iconPlay = playBtn?.querySelector(".ip-icon-play") as SVGElement | null;
  const iconPause = playBtn?.querySelector(".ip-icon-pause") as SVGElement | null;
  const progress = document.getElementById("ip-progress");
  const fill = document.getElementById("ip-progress-fill");
  const timeEl = document.getElementById("ip-time");

  if (audio && playBtn && iconPlay && iconPause && progress && fill && timeEl) {
    const fmt = (s: number) => {
      if (!isFinite(s)) return "--:--";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${String(m).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
    };

    playBtn.addEventListener("click", () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    audio.addEventListener("play", () => {
      iconPlay.style.display = "none";
      iconPause.style.display = "";
    });
    audio.addEventListener("pause", () => {
      iconPlay.style.display = "";
      iconPause.style.display = "none";
    });
    audio.addEventListener("loadedmetadata", () => {
      timeEl.textContent = `00:00 / ${fmt(audio.duration)}`;
    });
    audio.addEventListener("timeupdate", () => {
      const pct = (audio.currentTime / audio.duration) * 100 || 0;
      fill.style.width = `${pct}%`;
      timeEl.textContent = `${fmt(audio.currentTime)} / ${fmt(audio.duration)}`;
    });
    progress.addEventListener("click", (e) => {
      const rect = progress.getBoundingClientRect();
      const ratio = ((e as MouseEvent).clientX - rect.left) / rect.width;
      audio.currentTime = ratio * audio.duration;
    });
  }
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero-fullpage {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -65px;
    padding: 95px 0 40px;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(10, 37, 64, 0.45) 0%,
      rgba(10, 37, 64, 0.25) 50%,
      rgba(10, 37, 64, 0.55) 100%
    );
  }

  .hero-waves {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 22vh;
    min-height: 140px;
    z-index: 2;
  }

  .wave-1 { animation: wave-slide 60s linear infinite; }
  .wave-2 { animation: wave-slide 80s linear infinite reverse; }
  .wave-3 { animation: wave-slide 50s linear infinite; }
  @keyframes wave-slide {
    from { transform: translateX(0); }
    to { transform: translateX(-60px); }
  }

  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: white;
    padding: 0 24px;
    max-width: 760px;
    animation: fadeUp 1.2s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 22px;
    padding: 6px 16px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 100px;
    backdrop-filter: blur(8px);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 500;
    line-height: 1.1;
    margin: 0 0 24px;
    color: white;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  .hero-lede {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.95);
    max-width: 560px;
    margin: 0 auto 28px;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.2);
  }

  .hero-subscribe :global(.sub-row) { justify-content: center; }
  .hero-subscribe :global(.sub-btn) {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.35);
    color: white;
    backdrop-filter: blur(10px);
  }
  .hero-subscribe :global(.sub-btn:hover) {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.55);
    color: white;
  }

  /* ── Intro audio player (below subscribe buttons) ────── */
  .intro-player {
    margin: 30px auto 0;
    max-width: 620px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      "play info time"
      "progress progress progress";
    align-items: center;
    gap: 10px 14px;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 18px;
    color: white;
  }

  .ip-play {
    grid-area: play;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 0;
    background: white;
    color: var(--c-brand);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.1s ease, box-shadow 0.15s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }
  .ip-play:hover { transform: scale(1.04); }
  .ip-play:active { transform: scale(0.96); }

  .ip-info {
    grid-area: info;
    text-align: left;
    min-width: 0;
  }
  .ip-eyebrow {
    display: block;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 2px;
  }
  .ip-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: white;
    line-height: 1.2;
  }

  .ip-time {
    grid-area: time;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.8);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .ip-progress {
    grid-area: progress;
    height: 4px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .ip-progress-fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0;
    background: white;
    border-radius: 4px;
    transition: width 0.1s linear;
  }

  /* ── Scroll indicator ────────────────────────────────── */
  .scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    width: 28px;
    height: 44px;
    border: 2px solid rgba(255, 255, 255, 0.6);
    border-radius: 14px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    animation: pulse 2.5s ease-in-out infinite;
  }
  .scroll-indicator span {
    width: 4px;
    height: 8px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 2px;
    animation: scroll-dot 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
  @keyframes scroll-dot {
    0% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.4; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* ── Recent + How sections ───────────────────────────── */
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .section-head h2 { margin: 0; }

  .all-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .episode-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }

  .how {
    background: var(--c-bg-card);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    text-align: center;
    margin-bottom: 80px;
  }
  .how h2 { margin-top: 14px; margin-bottom: 48px; }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px;
    text-align: left;
  }
  .step h3 { margin: 14px 0 8px; }
  .step p {
    color: var(--c-ink-muted);
    font-size: 0.95rem;
    margin: 0;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--c-brand);
    letter-spacing: 0.1em;
  }

  @media (max-width: 720px) {
    .intro-player {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "play info"
        "progress progress"
        "time time";
    }
    .ip-time { text-align: right; }
  }
</style>
