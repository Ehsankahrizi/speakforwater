---
import Layout from "../layouts/Layout.astro";
import SubscribeButtons from "../components/SubscribeButtons.astro";
---

<Layout
  title="Subscribe to SpeakForWater"
  description="Get a new water research podcast every weekday morning. Subscribe on Apple Podcasts, Spotify, or via RSS."
>
  <section class="sub-hero">
    <div class="container-narrow">
      <span class="eyebrow">Subscribe</span>
      <h1>One paper, every morning.</h1>
      <p class="lede">
        SpeakForWater publishes every weekday at 7am UTC. Pick your favorite
        platform below — or paste the RSS feed into any podcast app.
      </p>

      <SubscribeButtons variant="grid" />
    </div>
  </section>

  <section class="rss-block">
    <div class="container-narrow">
      <h2>Universal RSS feed</h2>
      <p>
        Use this URL with any podcast app (Pocket Casts, Overcast, Castro,
        Antennapod, etc.):
      </p>
      <div class="rss-box">
        <code>https://speakforwater.com/podcast.xml</code>
        <button class="copy-btn" data-copy="https://speakforwater.com/podcast.xml">
          Copy
        </button>
      </div>
    </div>
  </section>

  <section class="newsletter" id="newsletter">
    <div class="container-narrow">
      <span class="eyebrow">Or read instead</span>
      <h2>The weekly digest</h2>
      <p>
        Prefer reading? Once a week, we send a short email recapping the five
        most important episodes — with links to papers, key findings, and topics
        to watch. Free, no spam, unsubscribe anytime.
      </p>
      <form class="newsletter-form" action="https://buttondown.email/api/emails/embed-subscribe/speakforwater" method="post" target="popupwindow">
        <input type="email" name="email" placeholder="you@example.com" required />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
      <p class="small muted">Powered by Buttondown · GDPR compliant · privacy-friendly</p>
    </div>
  </section>
</Layout>

<style>
  .sub-hero {
    padding: 80px 0 56px;
  }

  .lede {
    font-size: 1.18rem;
    color: var(--c-ink-muted);
    line-height: 1.6;
    margin: 18px 0 36px;
  }

  .rss-block {
    padding: 56px 0;
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    background: var(--c-brand-tint);
  }

  .rss-block h2 { margin-bottom: 12px; }

  .rss-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border-strong);
    border-radius: var(--radius);
    padding: 6px 6px 6px 16px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    margin-top: 18px;
  }

  .rss-box code {
    flex: 1;
    overflow-x: auto;
    color: var(--c-ink);
  }

  .copy-btn {
    padding: 8px 16px;
    background: var(--c-ink);
    color: white;
    border: 0;
    border-radius: var(--radius-sm);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .copy-btn:hover { background: var(--c-brand-deep); }

  .newsletter {
    padding: 80px 0 96px;
  }

  .newsletter h2 { margin-top: 14px; margin-bottom: 14px; }

  .newsletter-form {
    display: flex;
    gap: 8px;
    max-width: 460px;
    margin: 24px 0 12px;
  }

  .newsletter-form input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--c-border-strong);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    background: var(--c-bg-card);
  }

  .newsletter-form input:focus {
    outline: 2px solid var(--c-brand);
    outline-offset: -1px;
    border-color: var(--c-brand);
  }

  .small { font-size: 0.82rem; }

  @media (max-width: 540px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = original), 1500);
      } catch {
        btn.textContent = "Copy failed";
      }
    });
  });
</script>
