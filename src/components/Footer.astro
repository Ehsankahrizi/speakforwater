---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="col col-brand">
      <span class="footer-brand">SpeakForWater</span>
      <p class="muted">
        Daily AI-narrated water research, distilled from peer-reviewed papers.
        An open project by Ehsan Kahrizi.
      </p>
    </div>

    <div class="col">
      <h4>Listen</h4>
      <a href="/subscribe">All platforms</a>
      <a href="/podcast.xml">RSS feed</a>
    </div>

    <div class="col">
      <h4>About</h4>
      <a href="/about">Our methodology</a>
      <a href="/about#ai">AI & ethics</a>
      <a href="https://github.com/Ehsankahrizi/speakforwater" rel="noopener">Open source</a>
    </div>

    <div class="col">
      <h4>Connect</h4>
      <a href="mailto:hello@speakforwater.com">Email</a>
      <a href="https://github.com/Ehsankahrizi" rel="noopener">GitHub</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span class="muted small">© {year} Ehsan Kahrizi · MIT licensed · Powered by NotebookLM</span>
    <span class="muted small">speakforwater.com</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-bg-card);
    border-top: 1px solid var(--c-border);
    padding: 56px 0 32px;
    margin-top: 80px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--c-border);
  }

  .col h4 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
    margin-bottom: 14px;
  }

  .col a {
    display: block;
    font-size: 0.92rem;
    color: var(--c-ink-soft);
    margin-bottom: 8px;
  }

  .col a:hover { color: var(--c-brand); }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--c-ink);
    margin-bottom: 8px;
    display: block;
  }

  .col-brand p {
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 320px;
    margin: 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .small { font-size: 0.82rem; }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .col-brand { grid-column: 1 / -1; }
  }
</style>
