---
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "";
const isActive = (path: string) =>
  path === "/" ? pathname === "/" : pathname.startsWith(path);
---

<header
  class:list={["site-header", { "transparent-mode": isHome }]}
  id="site-header"
>
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="SpeakForWater home">
      <svg class="brand-mark" width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <circle class="brand-circle" cx="14" cy="14" r="14" fill="#E6F1FB" />
        <path
          class="brand-drop"
          d="M14 6c-2.5 3.5-5 6.2-5 9a5 5 0 0010 0c0-2.8-2.5-5.5-5-9z"
          fill="#185FA5"
        />
      </svg>
      <span>SpeakForWater</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <a href="/episodes" class:list={[{ active: isActive("/episodes") }]}>Episodes</a>
      <a href="/about" class:list={[{ active: isActive("/about") }]}>About</a>
      <a href="/subscribe" class:list={[{ active: isActive("/subscribe") }]}>Subscribe</a>
    </nav>
  </div>
</header>

<script>
  // Toggle a `scrolled` class on the header once user scrolls a bit.
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--c-border);
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
  }

  /* Homepage: transparent at top, becomes opaque on scroll */
  .site-header.transparent-mode {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom-color: transparent;
  }

  .site-header.transparent-mode.scrolled {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom-color: var(--c-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    padding-bottom: 16px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    transition: color 0.35s ease;
  }

  .brand:hover { color: var(--c-ink); }

  .brand-circle, .brand-drop {
    transition: fill 0.35s ease;
  }

  /* Brand colors when transparent over hero */
  .site-header.transparent-mode:not(.scrolled) .brand {
    color: white;
  }
  .site-header.transparent-mode:not(.scrolled) .brand-circle {
    fill: rgba(255, 255, 255, 0.18);
  }
  .site-header.transparent-mode:not(.scrolled) .brand-drop {
    fill: white;
  }

  .primary-nav {
    display: flex;
    gap: 28px;
  }

  .primary-nav a {
    font-size: 0.92rem;
    color: var(--c-ink-muted);
    font-weight: 500;
    position: relative;
    padding: 4px 0;
    transition: color 0.35s ease;
  }

  .primary-nav a:hover {
    color: var(--c-ink);
  }

  .primary-nav a.active {
    color: var(--c-ink);
  }

  .primary-nav a.active::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 2px;
    background: var(--c-brand);
    border-radius: 2px;
  }

  /* Nav colors when transparent over hero */
  .site-header.transparent-mode:not(.scrolled) .primary-nav a {
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.25);
  }
  .site-header.transparent-mode:not(.scrolled) .primary-nav a:hover,
  .site-header.transparent-mode:not(.scrolled) .primary-nav a.active {
    color: white;
  }
  .site-header.transparent-mode:not(.scrolled) .primary-nav a.active::after {
    background: white;
  }

  @media (max-width: 560px) {
    .primary-nav { gap: 18px; }
    .primary-nav a { font-size: 0.85rem; }
  }
</style>
