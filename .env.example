# ── SpeakForWater API Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.

# API authentication key — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=changeme-generate-a-real-key

# Server settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Browser settings
HEADLESS=true
BROWSER_TIMEOUT=600

# (Optional) Connect to a remote browserless instance instead of local Chromium
# BROWSERLESS_URL=ws://browserless:3000

# NotebookLM
NOTEBOOKLM_URL=https://notebooklm.google.com

# Notebook cleanup
KEEP_NOTEBOOKS=false
MAX_STORED_MP3S=50
